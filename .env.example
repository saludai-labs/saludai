# SaludAI — Environment Variables
# Copy to .env and fill in your values

# FHIR Server
SALUDAI_FHIR_SERVER_URL=http://localhost:8080/fhir
SALUDAI_FHIR_AUTH_TYPE=none

# LLM Provider (anthropic | openai | ollama)
SALUDAI_LLM_PROVIDER=anthropic
SALUDAI_LLM_MODEL=claude-sonnet-4-5-20250929
SALUDAI_LLM_TEMPERATURE=0.0

# API Keys (set your real keys here)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Ollama (local development)
SALUDAI_OLLAMA_BASE_URL=http://localhost:11434
SALUDAI_OLLAMA_MODEL=llama3.1:8b

# Langfuse (observability)
SALUDAI_LANGFUSE_ENABLED=true
SALUDAI_LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here

# Agent
SALUDAI_AGENT_MAX_ITERATIONS=8
SALUDAI_AGENT_TIMEOUT_SECONDS=60
