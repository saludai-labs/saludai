# SaludAI — Environment Variables
# Copy to .env and fill in your values

# FHIR Server
SALUDAI_FHIR_SERVER_URL=http://localhost:8080/fhir
SALUDAI_FHIR_AUTH_TYPE=none

# LLM Provider (anthropic | openai | ollama)
SALUDAI_LLM_PROVIDER=anthropic
SALUDAI_LLM_MODEL=claude-sonnet-4-5-20250929
SALUDAI_LLM_TEMPERATURE=0.0

# --- API Keys ---

# Anthropic (Claude Sonnet, Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-your-key-here

# Together AI (Llama 3.3 70B, Qwen 2.5 72B — cloud inference for open-source models)
# Sign up: https://api.together.xyz — $5 free credit
TOGETHER_API_KEY=your-together-key-here

# --- Cloud inference for open-source models ---
# To run Llama/Qwen via Together AI, set:
#   SALUDAI_LLM_PROVIDER=ollama
#   SALUDAI_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
#   SALUDAI_LLM_BASE_URL=https://api.together.xyz/v1
#   SALUDAI_LLM_API_KEY=$TOGETHER_API_KEY
#
# Available models on Together:
#   meta-llama/Llama-3.3-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct

# Ollama (local development — requires local Ollama install)
# SALUDAI_LLM_BASE_URL=http://localhost:11434/v1
# SALUDAI_LLM_MODEL=llama3.1:8b

# Langfuse (observability)
SALUDAI_LANGFUSE_ENABLED=true
SALUDAI_LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here

# Agent
SALUDAI_AGENT_MAX_ITERATIONS=12
SALUDAI_AGENT_TIMEOUT_SECONDS=60
